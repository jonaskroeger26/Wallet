# Optional: custom RPC URLs (Helius, Triton, etc.). Leave unset to use Solana public RPC.
# VITE_SOLANA_RPC_DEVNET=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# VITE_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional: Helius API key for Collectibles tab (NFT / DAS-style list).
# VITE_HELIUS_API_KEY=

# The in-app AI assistant is offline (see src/lib/local-assistant.ts) — no API keys required.

# --- Discord Rich Presence (developers only, local machine) ---
# Shows “Playing OwnWallet” in Discord desktop while `npm run discord:presence` or `npm run dev:discord` runs.
# Create an app at https://discord.com/developers/applications and paste the Application ID (public).
# DISCORD_CLIENT_ID=
# Optional copy overrides:
# DISCORD_PRESENCE_DETAILS=OwnWallet
# DISCORD_PRESENCE_STATE=Working on Solana wallet
# Optional Rich Presence art asset key from the Developer Portal (must upload image first):
# DISCORD_ASSET_KEY=logo
# DISCORD_ASSET_TEXT=OwnWallet
