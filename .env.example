# Optional: custom RPC URLs (Helius, Triton, etc.). Leave unset to use Solana public RPC.
# VITE_SOLANA_RPC_DEVNET=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# VITE_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional: Helius API key for Collectibles tab (NFT / DAS-style list).
# VITE_HELIUS_API_KEY=

# The in-app AI assistant is offline (see src/lib/local-assistant.ts) — no API keys required.
