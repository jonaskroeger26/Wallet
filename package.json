{
  "name": "wallet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run test:run && npm run build",
    "discord:presence": "node scripts/discord-presence.mjs",
    "dev:discord": "concurrently -k -n vite,discord -c cyan,magenta \"npm run dev\" \"node scripts/discord-presence.mjs\""
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "ed25519-hd-key": "^1.3.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bip39": "^2.4.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.1.2"
  }
}
